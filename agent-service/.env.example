# OpenAI配置
OPENAI_API_KEY=your-openai-api-key-here

# 数据库配置（Agent服务连接后端数据库）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=elderly_care
DB_USER=root
DB_PASSWORD=password

# 服务器配置
AGENT_PORT=8001

# 风险分析配置
RISK_THRESHOLD_HIGH=0.8
RISK_THRESHOLD_MEDIUM=0.5

# 定时任务配置
DAILY_CHECK_TIME=08:00
WEEKLY_REPORT_DAY=1  # 周一
MONTHLY_REPORT_DAY=1 # 每月1号