# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=elderly_care
DB_USER=root
DB_PASSWORD=password

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-here

# 服务器配置
PORT=8000
NODE_ENV=development
DB_SYNC_ALTER=false

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# Redis配置（可选）
REDIS_URL=redis://localhost:6379

# ---- 医疗紧急通知（家属联动） ----
# 企业微信机器人（可选）
WECOM_ENABLED=false
WECOM_WEBHOOK_URL=

# 短信渠道（none | twilio | webhook）
SMS_PROVIDER=none

# Twilio（当 SMS_PROVIDER=twilio 时使用）
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# 自定义短信网关（当 SMS_PROVIDER=webhook 时使用）
SMS_WEBHOOK_URL=
SMS_WEBHOOK_TOKEN=

# AI Agent（通义千问）
AI_AGENT_ENABLED=false
QWEN_API_KEY=
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
